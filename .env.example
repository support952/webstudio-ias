# ===========================================
# WebStudio IAS – משתני סביבה
# ===========================================

# --- שרת ---
NODE_ENV=development
PORT=5000

# --- מסד נתונים (PostgreSQL) ---
# אם לא מוגדר – הפרויקט עובד עם אחסון בזיכרון
DATABASE_URL=postgres://user:password@localhost:5432/webstudio_ias

# --- סשן (חובה ב-production) ---
SESSION_SECRET=please_change_me_to_a_strong_random_string

# --- מנהל מערכת (התחברות לפאנל) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_admin_password

# --- טופס יצירת קשר ---
# המייל שלך – לכאן יגיעו פניות מהטופס והשאלון
CONTACT_EMAIL=your-email@example.com

# --- SMTP – שליחת מיילים ---
# חובה כדי שפניות וסיכום AI יישלחו במייל
# SMTP_HOST = שרת המייל (לא כתובת!). Gmail: smtp.gmail.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# --- סוכן AI (שלב 3 בזרימת יצירת קשר) ---
# מפתח: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
# אופציונלי: מודל (ברירת מחדל gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# אופציונלי: רק אם משתמשים ב-endpoint אחר (proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1
